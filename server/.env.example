# Copy to .env in this folder and adjust. Values are loaded by server/settings.py
# (python-dotenv). OS environment variables still override these if set (override=False).

# Repository root (default: parent directory of server/)
# REPO_ROOT=

# Bind address for: python -m server.main
HOST=127.0.0.1

# HTTP port (also checked: UVICORN_PORT if PORT is unset)
PORT=8000
# UVICORN_PORT=

# Secret for signed session cookies — change in production
SESSION_SECRET=dev-change-me

# Set to 1 to git commit after moderator applies an edit
GIT_AUTO_COMMIT=0
