# Copy to .env in this folder. Used by Vite (vite.config.ts via loadEnv). Restart
# `npm run dev` or rebuild after changes.

# Public URL path where the app is mounted (must start with / and usually end with /).
# Default matches production Apache ProxyPass. For local dev at site root, set VITE_BASE_PATH=/
VITE_BASE_PATH=/gdelt-wildlife/

# Port the API listens on (must match server PORT)
VITE_API_PORT=8000

# Host where FastAPI runs (Vite dev proxy target)
VITE_API_HOST=127.0.0.1
