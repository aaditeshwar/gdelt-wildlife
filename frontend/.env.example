# Copy to .env in this folder. Used by Vite (vite.config.ts via loadEnv) for the
# dev-server proxy to the FastAPI backend. Restart `npm run dev` after changes.

# Port the API listens on (must match server PORT)
VITE_API_PORT=8000

# Optional: host where FastAPI runs (proxy target)
VITE_API_HOST=127.0.0.1
