# Copy to .env in this directory (repository root). Do not commit .env.
# Pipeline scripts load this file via python-dotenv (existing OS environment variables win).
#
# Other env files in this repo:
#   server/.env.example  — FastAPI host, port, SESSION_SECRET (see server/settings.py)
#   frontend/.env.example — Vite dev proxy and public base path

# --- Google Maps Geocoding (optional; scripts/gdelt-get-full-text.py) ---
# Enable Geocoding API in Google Cloud Console for the same project as the key.
GOOGLE_MAPS_API_KEY=

# --- Ollama LLM (scripts/gdelt-get-full-text.py) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_TIMEOUT=120

# --- Jina reader base URL (optional; default https://r.jina.ai/) ---
# JINA_BASE=https://r.jina.ai/

# --- Article text cache directory (optional; scripts/gdelt-get-full-text.py) ---
# Overrides default data/{prefix}_article_text/ for {event_id}.txt snapshots.
# GDELT_ARTICLE_TEXT_DIR=

# --- Google Cloud / BigQuery (scripts/gdelt-enrich-urls-bigquery.py) ---
# Default for --project when omitted. Also used by the Google client libraries.
GOOGLE_CLOUD_PROJECT=
# Optional: path to service account JSON (if not using gcloud auth application-default login)
GOOGLE_APPLICATION_CREDENTIALS=
