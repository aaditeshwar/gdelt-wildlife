# Apache 2.4: app at https://SERVERNAME/gdelt-wildlife/
#
# This matches the usual split: Apache serves frontend/dist (Alias + FallbackResource),
# and only /api is proxied to Uvicorn. Uvicorn does not need to serve static files for
# public traffic (see README — alternative: ProxyPass everything to Uvicorn if you prefer).
#
# Build the SPA with the same path:
#   cd frontend && VITE_BASE_PATH=/gdelt-wildlife/ npm run build
#
# Adjust REPO_ROOT below, ServerName, and SSL paths.
#
#   sudo a2enmod proxy proxy_http headers ssl alias
#   sudo apache2ctl configtest && sudo systemctl reload apache2

# --- HTTP (port 80) ---
<VirtualHost *:80>
    ServerName 10.237.20.197
    ServerAdmin webmaster@localhost

    ProxyPreserveHost On
    RequestHeader set X-Forwarded-Proto "http"
    RequestHeader set X-Forwarded-Port "80"

    # API to Uvicorn (list these before Alias so /api wins over static)
    ProxyPass /gdelt-wildlife/api http://127.0.0.1:8000/api
    ProxyPassReverse /gdelt-wildlife/api http://127.0.0.1:8000/api

    # SPA: static build (same pattern as archive-search / agromet-advisory)
    # Replace with your repo path, e.g. /home/aseth/core-stack/gdelt-wildlife/frontend/dist
    Alias /gdelt-wildlife "/srv/gdelt-wildlife/frontend/dist"
    <Directory "/srv/gdelt-wildlife/frontend/dist">
        Require all granted
        Options -Indexes +FollowSymLinks
        AllowOverride None
        FallbackResource /gdelt-wildlife/index.html
    </Directory>

    ErrorLog ${APACHE_LOG_DIR}/gdelt-wildlife-error.log
    CustomLog ${APACHE_LOG_DIR}/gdelt-wildlife-access.log combined
</VirtualHost>

# --- HTTPS (port 443): optional; duplicate the same ProxyPass + Alias inside ---
# <VirtualHost *:443>
#     ServerName 10.237.20.197
#     SSLEngine on
#     SSLCertificateFile ...
#     SSLCertificateKeyFile ...
#     ProxyPreserveHost On
#     RequestHeader set X-Forwarded-Proto "https"
#     RequestHeader set X-Forwarded-Port "443"
#     ProxyPass /gdelt-wildlife/api http://127.0.0.1:8000/api
#     ProxyPassReverse /gdelt-wildlife/api http://127.0.0.1:8000/api
#     Alias /gdelt-wildlife "/srv/gdelt-wildlife/frontend/dist"
#     <Directory "/srv/gdelt-wildlife/frontend/dist">
#         Require all granted
#         Options -Indexes +FollowSymLinks
#         AllowOverride None
#         FallbackResource /gdelt-wildlife/index.html
#     </Directory>
# </VirtualHost>

# --- Alternative (not used if you use Alias above): send all traffic to Uvicorn ---
# FastAPI also mounts frontend/dist; Apache would only need:
#   ProxyPass /gdelt-wildlife/ http://127.0.0.1:8000/
#   ProxyPassReverse /gdelt-wildlife/ http://127.0.0.1:8000/
